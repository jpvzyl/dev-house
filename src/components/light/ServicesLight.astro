<hr class="section-divider" />

<section class="section" id="services">
  <div class="container">
    <div class="services-header" data-animate>
      <span class="section-eyebrow">Capabilities</span>
      <h2 class="section-title">Full-Spectrum Engineering</h2>
      <p class="section-subtitle">
        Deep expertise across the entire technology landscape &mdash; from
        cutting-edge quantum computing to battle-tested enterprise platforms.
      </p>
    </div>

    <div class="services-list">
      {services.map((s, i) => (
        <div class="service-item" data-animate data-delay={String(Math.min(i % 3 + 1, 3))}>
          <span class="service-num">{s.num}</span>
          <div class="service-body">
            <h3 class="service-name">{s.title}</h3>
            <p class="service-desc">{s.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services-header {
    margin-bottom: 3.5rem;
  }

  .services-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .service-item {
    background: var(--bg);
    padding: 2rem 2.25rem;
    transition: background var(--transition);
  }

  .service-item:hover {
    background: var(--bg-surface);
  }

  .service-num {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-muted);
    display: block;
    margin-bottom: 1rem;
  }

  .service-name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
    color: var(--text-primary);
  }

  .service-desc {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  @media (max-width: 960px) {
    .services-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .services-list {
      grid-template-columns: 1fr;
    }
  }
</style>
