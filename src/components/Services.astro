---
const services = [
  {
    icon: `<circle cx="12" cy="12" r="2.5"/><ellipse cx="12" cy="12" rx="9" ry="3.5"/><ellipse cx="12" cy="12" rx="9" ry="3.5" transform="rotate(60 12 12)"/><ellipse cx="12" cy="12" rx="9" ry="3.5" transform="rotate(120 12 12)"/>`,
    title: 'Quantum Computing',
    description: 'Hybrid quantum-classical optimization frameworks leveraging AWS Braket, Qiskit, and D-Wave. QUBO encoding, combinatorial solvers, and production APIs with intelligent classical fallback.',
  },
  {
    icon: `<path d="M12 2.5L3.5 7v5.5c0 5.2 3.6 10 8.5 11.5 4.9-1.5 8.5-6.3 8.5-11.5V7L12 2.5z" stroke-linejoin="round"/><path d="M9 12.5l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>`,
    title: 'Penetration Testing',
    description: 'AI-augmented static analysis and vulnerability assessment with OWASP and CWE classification. Automated scanning, risk scoring, and comprehensive remediation reporting.',
  },
  {
    icon: `<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z" stroke-linejoin="round"/><path d="M14 2v6h6" stroke-linejoin="round"/><path d="M9 15l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>`,
    title: 'ISO 27001 Certification',
    description: 'Complete compliance management covering all 93 Annex A controls. Statement of applicability, evidence tracking, gap analysis, risk registers, and full certification roadmap.',
  },
  {
    icon: `<circle cx="12" cy="6" r="2"/><circle cx="6" cy="14" r="2"/><circle cx="18" cy="14" r="2"/><circle cx="12" cy="20" r="2"/><path d="M12 8v3M8 13l2.5-2M16 13l-2.5-2M10 18.5L8.5 16M14 18.5l1.5-2.5" stroke-linecap="round"/>`,
    title: 'AI & Intelligent Systems',
    description: 'Production LLM integrations, conversational AI agents, computer vision pipelines, and autonomous reasoning systems. Claude, OpenAI, LangChain, and AWS Rekognition.',
  },
  {
    icon: `<rect x="2" y="4" width="20" height="16" rx="2" stroke-linejoin="round"/><path d="M2 9h20"/><path d="M8 15l-2.5 2L8 19" stroke-linecap="round" stroke-linejoin="round"/><path d="M16 15l2.5 2L16 19" stroke-linecap="round" stroke-linejoin="round"/><path d="M13 14l-2 6" stroke-linecap="round"/>`,
    title: 'Custom Web Platforms',
    description: 'Full-stack engineering with Rails, FastAPI, Django, and Next.js. Real-time WebSocket architectures, complex data models, and enterprise-grade APIs — built for scale.',
  },
  {
    icon: `<rect x="6" y="2" width="12" height="20" rx="3" stroke-linejoin="round"/><path d="M12 18h.01" stroke-linecap="round" stroke-width="2"/>`,
    title: 'Mobile Applications',
    description: 'Cross-platform development with React Native and Expo. Camera, GPS, biometric authentication, offline-first sync — from consumer products to industrial tools.',
  },
  {
    icon: `<rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/>`,
    title: 'Enterprise Platforms',
    description: 'ERP, CRM, QA automation, and financial systems. Multi-tenant architectures, role-based access, third-party integrations, and comprehensive reporting dashboards.',
  },
  {
    icon: `<rect x="2" y="7" width="7.5" height="10" rx="1.5"/><rect x="14.5" y="7" width="7.5" height="10" rx="1.5"/><path d="M9.5 12h5" stroke-linecap="round"/><path d="M9.5 10h5" stroke-linecap="round"/><path d="M9.5 14h5" stroke-linecap="round"/>`,
    title: 'Blockchain & Fintech',
    description: 'P2P trading platforms, multi-currency escrow, Web3 wallet integration, and KYC/AML pipelines. High-performance Rust backends for maximum throughput and security.',
  },
  {
    icon: `<circle cx="12" cy="12" r="3"/><path d="M12 1.5v3M12 19.5v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M1.5 12h3M19.5 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12" stroke-linecap="round"/>`,
    title: 'Robotics & IoT',
    description: 'Hardware control systems, real-time WebSocket command interfaces, computer vision, and cloud IoT integration. Prototyping through to production-ready control centres.',
  },
];
---

<section class="section" id="services">
  <div class="container">
    <div class="section-header" data-animate>
      <span class="section-label">Capabilities</span>
      <h2 class="section-title">Full-Spectrum Engineering</h2>
      <p class="section-subtitle">
        Deep expertise across the entire technology landscape &mdash; from cutting-edge
        quantum computing to battle-tested enterprise platforms.
      </p>
    </div>

    <div class="services-grid">
      {services.map((s, i) => (
        <div class="service-card card" data-animate data-delay={String(Math.min(i + 1, 6))}>
          <div class="service-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" set:html={s.icon} />
          </div>
          <h3 class="service-title">{s.title}</h3>
          <p class="service-desc">{s.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .service-card:hover .service-icon {
    background: rgba(99, 102, 241, 0.12);
    border-color: rgba(99, 102, 241, 0.25);
  }

  .service-card:hover .service-icon svg {
    stroke: var(--accent-indigo);
  }

  .service-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    background: rgba(99, 102, 241, 0.06);
    border: 1px solid rgba(99, 102, 241, 0.1);
    transition: all var(--transition);
  }

  .service-icon svg {
    width: 24px;
    height: 24px;
    stroke: var(--text-secondary);
    transition: stroke var(--transition);
  }

  .service-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
  }

  .service-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
